DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
PORT=3001
FRONTEND_URL="http://localhost:3000"
GBOX_API_BASE_URL="https://gbox-api.example.com"

# Backend-only Supabase Data API connection. Never use the secret in frontend code.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_replace_me"
# Optional deployment metadata; API calls do not require the region.
SUPABASE_REGION="eu-west-1"
SUPABASE_DB_SCHEMA="public"

# Prefer immutable deployment metadata so /version does not need a data call.
APP_VERSION="1.0.0"
# Only used when APP_VERSION is omitted and system_config is read through PostgREST.
APP_VERSION_CACHE_TTL_MS="300000"
